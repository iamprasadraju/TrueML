   "source": [
    "import numpy as np\n",
    "import trueml.plots as plt\n",
    "\n",
    "x = np.linspace(-5, 5, 100)\n",
    "y = np.linspace(-5, 5, 100)\n",
    "\n",
    "X, Y = np.meshgrid(x, y)\n",
    "Z = X**2 + Y**2\n",
    "\n",
    "plt.contour(\n",
    "    X,\n",
    "    Y,\n",
    "    Z,\n",
    "    title=\"Quadratic Function\",\n",
    "    xlabel=\"X\",\n",
    "    ylabel=\"Y\",\n",
    ")"
   ]
  }
 ],
